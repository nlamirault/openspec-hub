---
import Layout from "../layouts/Layout.astro";
import catalog from "../../public/data/catalog.json";
import {
  Cloud,
  Database,
  Network,
  ShieldCheck,
  Settings2,
  Activity,
  Cpu,
  GitBranch,
  Layers,
  Search,
} from "lucide-react";

const groups = Object.entries(catalog.groups);
const totalResources = Object.values(catalog.groups).flat().length;
const uniqueProviders = new Set(
  Object.keys(catalog.groups).map(g => g.split('.').slice(-2).join('.'))
).size;

// Categorization Logic
const categories = [
  {
    name: "AWS Infrastructure",
    icon: Cloud,
    color: "text-orange-500",
    bg: "bg-orange-50 dark:bg-orange-900/20",
    border: "border-orange-100 dark:border-orange-900/40",
    topBorder: "border-t-2 border-t-orange-300 dark:border-t-orange-500",
    description: "ACK controllers and AWS service operators for managing cloud infrastructure",
    match: (g: string) => g.includes("aws") || g.includes("amazon"),
  },
  {
    name: "Google Cloud",
    icon: Cloud,
    color: "text-blue-500",
    bg: "bg-blue-50 dark:bg-blue-900/20",
    border: "border-blue-100 dark:border-blue-900/40",
    topBorder: "border-t-2 border-t-blue-400 dark:border-t-blue-500",
    description: "Config Connector CRDs for provisioning and managing GCP services",
    match: (g: string) => g.includes("google") || g.includes("cnrm"),
  },
  {
    name: "Azure Ecosystem",
    icon: Cloud,
    color: "text-sky-600",
    bg: "bg-sky-50 dark:bg-sky-900/20",
    border: "border-sky-100 dark:border-sky-900/40",
    topBorder: "border-t-2 border-t-sky-400 dark:border-t-sky-500",
    description: "Azure Service Operator resources for declarative Azure resource management",
    match: (g: string) => g.includes("azure") || g.includes("microsoft"),
  },
  {
    name: "GitOps & Deployment",
    icon: GitBranch,
    color: "text-emerald-600",
    bg: "bg-emerald-50 dark:bg-emerald-900/20",
    border: "border-emerald-100 dark:border-emerald-900/40",
    topBorder: "border-t-2 border-t-emerald-400 dark:border-t-emerald-500",
    description: "Argo CD, Argo Events, Flux CD, and Kargo continuous delivery resources",
    match: (g: string) =>
      g.includes("argoproj") || g.includes("fluxcd") || g.includes("kargo"),
  },
  {
    name: "Databases & Storage",
    icon: Database,
    color: "text-indigo-600",
    bg: "bg-indigo-50 dark:bg-indigo-900/20",
    border: "border-indigo-100 dark:border-indigo-900/40",
    topBorder: "border-t-2 border-t-indigo-400 dark:border-t-indigo-500",
    description: "Database operators for PostgreSQL, MySQL, Redis, and ClickHouse",
    match: (g: string) =>
      g.includes("dbfor") ||
      g.includes("redis") ||
      g.includes("mariadb") ||
      g.includes("mysql") ||
      g.includes("postgresql") ||
      g.includes("clickhouse"),
  },
  {
    name: "Observability",
    icon: Activity,
    color: "text-rose-500",
    bg: "bg-rose-50 dark:bg-rose-900/20",
    border: "border-rose-100 dark:border-rose-900/40",
    topBorder: "border-t-2 border-t-rose-400 dark:border-t-rose-500",
    description: "Monitoring, tracing, and alerting with Prometheus, Grafana, and OpenTelemetry",
    match: (g: string) =>
      g.includes("monitoring") ||
      g.includes("grafana") ||
      g.includes("opentelemetry") ||
      g.includes("prometheus"),
  },
  {
    name: "Networking & Mesh",
    icon: Network,
    color: "text-violet-600",
    bg: "bg-violet-50 dark:bg-violet-900/20",
    border: "border-violet-100 dark:border-violet-900/40",
    topBorder: "border-t-2 border-t-violet-400 dark:border-t-violet-500",
    description: "Istio, Gateway API, and Envoy service mesh and ingress resources",
    match: (g: string) =>
      g.includes("networking") ||
      g.includes("istio") ||
      g.includes("gateway") ||
      g.includes("envoy"),
  },
  {
    name: "Security",
    icon: ShieldCheck,
    color: "text-red-600",
    bg: "bg-red-50 dark:bg-red-900/20",
    border: "border-red-100 dark:border-red-900/40",
    topBorder: "border-t-2 border-t-red-400 dark:border-t-red-500",
    description: "cert-manager, external-secrets, Doppler, and IAM CRDs for secrets and certificates",
    match: (g: string) =>
      g.includes("security") ||
      g.includes("cert-manager") ||
      g.includes("external-secrets") ||
      g.includes("doppler") ||
      g.includes("iam") ||
      g.includes("kms"),
  },
  {
    name: "Core Kubernetes",
    icon: Cpu,
    color: "text-blue-700",
    bg: "bg-blue-50 dark:bg-blue-900/20",
    border: "border-blue-100 dark:border-blue-900/40",
    topBorder: "border-t-2 border-t-blue-600 dark:border-t-blue-500",
    description: "Native Kubernetes API resources, extensions, and cluster management",
    match: (g: string) => g.includes("k8s.io"),
  },
];

// Group the actual data into categories
const groupedData = categories
  .map((cat) => {
    const matchedGroups = groups.filter(([name]) => cat.match(name));
    return {
      ...cat,
      groups: matchedGroups,
      count: matchedGroups.reduce((acc, [_, res]) => acc + res.length, 0),
    };
  })
  .filter((cat) => cat.groups.length > 0);

// Anything left over goes into "Other"
const matchedGroupNames = new Set(
  groupedData.flatMap((cat) => cat.groups.map(([name]) => name)),
);
const otherGroups = groups.filter(([name]) => !matchedGroupNames.has(name));

if (otherGroups.length > 0) {
  groupedData.push({
    name: "Other Extensions",
    icon: Layers,
    color: "text-gray-500",
    bg: "bg-gray-50 dark:bg-slate-800/50",
    border: "border-gray-200 dark:border-slate-700",
    topBorder: "border-t-2 border-t-gray-300 dark:border-t-slate-600",
    description: "Additional community and vendor CRD extensions",
    groups: otherGroups,
    count: otherGroups.reduce((acc, [_, res]) => acc + res.length, 0),
    match: () => true,
  });
}

// Build flat resource list for hero search
const allResources = groups.flatMap(([group, resources]) =>
  resources.map((res) => ({ kind: res.kind, group, version: res.version, slug: res.slug }))
);
---

<Layout title="Home">
  <!-- Hero -->
  <div class="relative overflow-hidden">
    <div class="hero-dots absolute inset-0 pointer-events-none"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-blue-50/60 dark:from-slate-900/80 to-white dark:to-slate-950 pointer-events-none"></div>

    <div class="relative max-w-6xl mx-auto px-6 pt-20 pb-16">
      <header class="mb-16 text-center">
        <div
          class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-50 dark:bg-blue-900/30 border border-blue-100 dark:border-blue-800 mb-6"
        >
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-500"></span>
          </span>
          <span class="text-[10px] font-black text-blue-600 dark:text-blue-400 uppercase tracking-widest">Open Source Registry</span>
        </div>
        <h1 class="text-7xl font-black text-gray-900 dark:text-white mb-6 tracking-tighter leading-none">
          OpenSpec <span class="text-blue-600">HUB</span>
        </h1>
        <p class="text-xl text-gray-500 dark:text-slate-400 max-w-2xl mx-auto leading-relaxed font-medium mb-10">
          The central directory for Kubernetes Custom Resource Definitions.
          Explore <strong class="text-gray-900 dark:text-white">{totalResources}</strong> standardized
          schemas across the cloud-native ecosystem.
        </p>

        <!-- Hero search -->
        <div class="relative max-w-xl mx-auto mb-4">
          <div class="relative">
            <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none">
              <Search size={16} className="text-gray-400" client:load />
            </div>
            <input
              id="hero-search"
              type="text"
              placeholder="Search schemas… e.g. Deployment, Ingress, Certificate"
              class="w-full pl-11 pr-4 py-3.5 border border-gray-200 dark:border-slate-700 rounded-2xl shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-white dark:bg-slate-900 text-gray-900 dark:text-slate-100 placeholder-gray-400 dark:placeholder-slate-500"
              autocomplete="off"
            />
          </div>
          <ul
            id="hero-results"
            class="absolute z-10 left-0 right-0 mt-2 bg-white dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-2xl shadow-xl overflow-hidden hidden"
            role="listbox"
          >
          </ul>
        </div>
        <!-- Search keyboard hints -->
        <p id="search-hints" class="text-[11px] text-gray-400 dark:text-slate-500 text-center hidden">
          <kbd class="px-1.5 py-0.5 bg-gray-100 dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded text-[10px] text-gray-500 dark:text-slate-400 font-mono">↑↓</kbd> navigate
          <kbd class="px-1.5 py-0.5 bg-gray-100 dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded text-[10px] text-gray-500 dark:text-slate-400 font-mono ml-2">↵</kbd> open
          <kbd class="px-1.5 py-0.5 bg-gray-100 dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded text-[10px] text-gray-500 dark:text-slate-400 font-mono ml-2">Esc</kbd> close
        </p>

        <!-- Stats row -->
        <div class="mt-10 flex flex-wrap justify-center gap-4">
          <div class="px-6 py-3 bg-white dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-2xl shadow-sm flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-blue-50 dark:bg-blue-900/30 flex items-center justify-center text-blue-600 dark:text-blue-400">
              <Settings2 size={20} />
            </div>
            <div class="text-left">
              <div class="text-[10px] font-bold text-gray-400 dark:text-slate-500 uppercase tracking-widest leading-none mb-1">Total Schemas</div>
              <div class="text-xl font-black text-gray-900 dark:text-white leading-none">{totalResources.toLocaleString()}</div>
            </div>
          </div>
          <div class="px-6 py-3 bg-white dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-2xl shadow-sm flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-purple-50 dark:bg-purple-900/30 flex items-center justify-center text-purple-600 dark:text-purple-400">
              <Layers size={20} />
            </div>
            <div class="text-left">
              <div class="text-[10px] font-bold text-gray-400 dark:text-slate-500 uppercase tracking-widest leading-none mb-1">API Groups</div>
              <div class="text-xl font-black text-gray-900 dark:text-white leading-none">{groups.length}</div>
            </div>
          </div>
          <div class="px-6 py-3 bg-white dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-2xl shadow-sm flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-emerald-50 dark:bg-emerald-900/30 flex items-center justify-center text-emerald-600 dark:text-emerald-400">
              <Cpu size={20} />
            </div>
            <div class="text-left">
              <div class="text-[10px] font-bold text-gray-400 dark:text-slate-500 uppercase tracking-widest leading-none mb-1">Categories</div>
              <div class="text-xl font-black text-gray-900 dark:text-white leading-none">{groupedData.length}</div>
            </div>
          </div>
          <div class="px-6 py-3 bg-white dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-2xl shadow-sm flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-amber-50 dark:bg-amber-900/30 flex items-center justify-center text-amber-600 dark:text-amber-400">
              <Network size={20} />
            </div>
            <div class="text-left">
              <div class="text-[10px] font-bold text-gray-400 dark:text-slate-500 uppercase tracking-widest leading-none mb-1">Providers</div>
              <div class="text-xl font-black text-gray-900 dark:text-white leading-none">{uniqueProviders}</div>
            </div>
          </div>
        </div>
      </header>
    </div>
  </div>

  <!-- Category grid -->
  <div class="max-w-6xl mx-auto px-6 pb-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        groupedData.map((cat) => (
          <div
            class={`p-8 border rounded-3xl transition-all hover:shadow-xl group hover:-translate-y-1 bg-white dark:bg-slate-900 ${cat.border} ${cat.topBorder}`}
          >
            <div class="flex items-start justify-between mb-6">
              <div
                class={`w-14 h-14 rounded-2xl flex items-center justify-center ${cat.bg} ${cat.color} group-hover:scale-110 transition-transform shadow-sm`}
              >
                <cat.icon size={28} />
              </div>
              <div class="text-right">
                <div class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-400 dark:text-slate-500 mb-1">Resources</div>
                <div class="text-2xl font-black text-gray-900 dark:text-white">{cat.count}</div>
              </div>
            </div>

            <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-2">{cat.name}</h2>
            <p class="text-sm text-gray-500 dark:text-slate-400 mb-6 leading-relaxed">{cat.description}</p>

            <div class="space-y-2">
              <div class="text-[10px] font-bold uppercase tracking-widest text-gray-400 dark:text-slate-500 mb-3">
                Popular Groups
              </div>
              <div class="flex flex-wrap gap-1.5">
                {cat.groups.slice(0, 5).map(([name, resources]) => (
                  <a
                    href={`/schemas/${(resources as any[])[0]?.slug ?? '#'}`}
                    class="px-2.5 py-1 bg-gray-50 dark:bg-slate-800 border border-gray-100 dark:border-slate-700 rounded-lg text-[10px] font-bold text-gray-500 dark:text-slate-400 hover:bg-white dark:hover:bg-slate-700 hover:border-blue-200 dark:hover:border-blue-700 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
                  >
                    {name.split(".").slice(0, 2).join(".")}
                  </a>
                ))}
                {cat.groups.length > 5 && (
                  <div class="text-[10px] font-bold text-gray-300 dark:text-slate-600 flex items-center ml-1">
                    + {cat.groups.length - 5} more
                  </div>
                )}
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</Layout>

<script define:vars={{ allResources }}>
  const input = /** @type {HTMLInputElement} */ (document.getElementById('hero-search'));
  const resultsList = document.getElementById('hero-results');
  const hints = document.getElementById('search-hints');
  let activeIndex = -1;

  function buildResultItem(resource, index) {
    const li = document.createElement('li');
    li.setAttribute('role', 'option');

    const a = document.createElement('a');
    a.href = `/schemas/${resource.slug}`;
    a.dataset.index = String(index);
    a.className = 'flex items-center justify-between px-4 py-3 hover:bg-blue-50 dark:hover:bg-blue-900/20 transition-colors border-b border-gray-50 dark:border-slate-800 last:border-0 group';

    const left = document.createElement('div');

    const kindSpan = document.createElement('span');
    kindSpan.className = 'text-sm font-semibold text-gray-900 dark:text-slate-100 group-hover:text-blue-700 dark:group-hover:text-blue-300';
    kindSpan.textContent = resource.kind;

    const groupSpan = document.createElement('span');
    groupSpan.className = 'text-xs text-gray-400 dark:text-slate-500 ml-2';
    groupSpan.textContent = resource.group.split('.').slice(0, 2).join('.');

    left.appendChild(kindSpan);
    left.appendChild(groupSpan);

    const versionSpan = document.createElement('span');
    versionSpan.className = 'text-[9px] px-1.5 py-0.5 bg-gray-100 dark:bg-slate-800 text-gray-400 dark:text-slate-500 rounded group-hover:bg-blue-100 dark:group-hover:bg-blue-900/30 group-hover:text-blue-500 dark:group-hover:text-blue-300';
    versionSpan.textContent = resource.version;

    a.appendChild(left);
    a.appendChild(versionSpan);
    li.appendChild(a);
    return li;
  }

  function renderResults(items) {
    if (!resultsList) return;
    while (resultsList.firstChild) resultsList.removeChild(resultsList.firstChild);

    if (!items.length) {
      resultsList.classList.add('hidden');
      if (hints) hints.classList.add('hidden');
      return;
    }

    items.slice(0, 8).forEach((r, i) => {
      resultsList.appendChild(buildResultItem(r, i));
    });

    resultsList.classList.remove('hidden');
    if (hints) hints.classList.remove('hidden');
    activeIndex = -1;
  }

  input?.addEventListener('input', (e) => {
    const q = /** @type {HTMLInputElement} */ (e.target).value.toLowerCase().trim();
    if (!q) {
      resultsList?.classList.add('hidden');
      if (hints) hints.classList.add('hidden');
      return;
    }
    const matches = allResources.filter(r =>
      r.kind.toLowerCase().includes(q) || r.group.toLowerCase().includes(q)
    );
    renderResults(matches);
  });

  input?.addEventListener('keydown', (e) => {
    const items = /** @type {NodeListOf<HTMLAnchorElement>} */ (resultsList?.querySelectorAll('a') ?? []);
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      activeIndex = Math.min(activeIndex + 1, items.length - 1);
      items.forEach((el, i) => el.classList.toggle('bg-blue-50', i === activeIndex));
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      activeIndex = Math.max(activeIndex - 1, -1);
      items.forEach((el, i) => el.classList.toggle('bg-blue-50', i === activeIndex));
    } else if (e.key === 'Enter' && activeIndex >= 0) {
      items[activeIndex]?.click();
    } else if (e.key === 'Escape') {
      resultsList?.classList.add('hidden');
      if (hints) hints.classList.add('hidden');
      input.blur();
    }
  });

  document.addEventListener('click', (e) => {
    if (!input?.contains(/** @type {Node} */ (e.target)) && !resultsList?.contains(/** @type {Node} */ (e.target))) {
      resultsList?.classList.add('hidden');
      if (hints) hints.classList.add('hidden');
    }
  });
</script>
